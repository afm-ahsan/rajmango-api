# RajMango API — Production Environment Variables
# -----------------------------------------------
# Set these on your server/container before starting the API.
# Do NOT commit a filled-in copy of this file to source control.
#
# Development: use `dotnet user-secrets set "Key" "Value"` instead.
# The UserSecretsId is: 412e7ab9-9612-4a5f-8a4c-145a24f4a9ce
#
# ASP.NET Core maps SECTION__KEY env vars to Section:Key config paths.

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# SQL Server connection string (must not be empty — app refuses to start without it)
CONNECTIONSTRINGS__DEFAULT=Server=HOST\SQLEXPRESS;Database=RajMango;User Id=sa;Password=YourPassword;TrustServerCertificate=True

# JWT signing secret — minimum 32 characters (app refuses to start if shorter)
SECURITY__JWT__CLIENTSECRET=replace-with-a-random-32-plus-character-secret

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# Redis connection string — omit or leave empty to fall back to in-process memory cache
# REDIS__CONNECTIONSTRING=localhost:6379,password=secret,ssl=false,abortConnect=False

# bKash payment gateway — omit if not using bKash
# BKASH__APPKEY=
# BKASH__APPSECRET=
# BKASH__USERNAME=
# BKASH__PASSWORD=
# BKASH__BASEURL=https://tokenized.pay.bka.sh/v1.2.0-beta/tokenized
# Full HTTPS URL bKash will redirect the browser to after payment
# BKASH__CALLBACKURL=https://api.rajmango.com/api/payments/bkash/callback
# Where the browser lands after callback is processed
# BKASH__FRONTENDSSUCCESSURL=https://rajmango.com/payment/success
# BKASH__FRONTENDFAILUREURL=https://rajmango.com/payment/failure
# BKASH__SANDBOXMODE=false
