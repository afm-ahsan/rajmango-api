# RajMango API — Production Environment Variables
# -----------------------------------------------
# Set these on your server/container before starting the API.
# Do NOT commit a filled-in copy of this file to source control.
#
# Development: credentials come from appsettings.Development.json (sandbox).
#              For dev-only overrides use `dotnet user-secrets` (UserSecretsId: 412e7ab9-9612-4a5f-8a4c-145a24f4a9ce).
#
# ASP.NET Core maps SECTION__KEY env vars to Section:Key config paths.
# Example: BKASH__APPKEY  →  Bkash:AppKey

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# SQL Server connection string (app refuses to start if empty)
CONNECTIONSTRINGS__DEFAULT=Server=HOST\SQLEXPRESS;Database=RajMango;User Id=sa;Password=YourPassword;TrustServerCertificate=True

# JWT signing secret — minimum 32 characters (app refuses to start if shorter)
SECURITY__JWT__CLIENTSECRET=replace-with-a-random-32-plus-character-secret

# bKash Tokenized Checkout — production credentials (app refuses to start if any are missing)
BKASH__APPKEY=<production app key from bKash merchant portal>
BKASH__APPSECRET=<production app secret from bKash merchant portal>
BKASH__USERNAME=<production merchant username>
BKASH__PASSWORD=<production merchant password>

# ── OPTIONAL — override the defaults from appsettings.json if needed ──────────

# Redis connection string — omit or leave empty to fall back to in-process memory cache
# REDIS__CONNECTIONSTRING=localhost:6379,password=secret,ssl=false,abortConnect=False

# bKash base URL — defaults to production gateway; only set if bKash issues a different URL
# BKASH__BASEURL=https://tokenized.pay.bka.sh/v1.2.0-beta/tokenized

# bKash callback and frontend redirect URLs — defaults match ajwadfarms.com production deployment
# BKASH__CALLBACKURL=https://api.ajwadfarms.com/api/payments/bkash/callback
# BKASH__FRONTENDSUCCESSURL=https://ajwadfarms.com/orders/bkash-success
# BKASH__FRONTENDFAILUREURL=https://ajwadfarms.com/orders/bkash-failed
# BKASH__FRONTENDCANCELURL=https://ajwadfarms.com/orders/bkash-cancelled

# bKash timeouts (seconds)
# BKASH__TIMEOUTSECONDS=15
# BKASH__PENDINGPAYMENTEXPIRYMINUTES=15

# SMS overrides
# SMS__ADMINMOBILENUMBER=01XXXXXXXXX
