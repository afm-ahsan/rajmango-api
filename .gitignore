# =============================================================================
# RajMango API — .gitignore
# Stack : .NET 8 · ASP.NET Core · EF Core · SQL Server Express · Redis
# IDEs  : Visual Studio 2022 · VS Code · JetBrains Rider
# CI/CD : GitHub Actions
# =============================================================================


# =============================================================================
# BUILD OUTPUTS
# =============================================================================

[Bb]in/
[Oo]bj/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
[Ll]og/
bld/
x64/
x86/
artifacts/


# =============================================================================
# .NET SDK & NUGET
# =============================================================================

*.nupkg
*.nuget.props
*.nuget.targets
project.lock.json
project.nuget.cache
**/packages/*
!**/packages/build/


# =============================================================================
# VISUAL STUDIO
# =============================================================================

# Solution user options (workspace-local IDE state)
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# VS cache / scratch
.vs/
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
ipch/
*.VC.db
*.VC.VC.opendb
*.opendb
*.opensdf
*.sdf
*.cachefile

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# Backup files generated when upgrading project format
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm


# =============================================================================
# VS CODE
# =============================================================================

.vscode/
*.code-workspace


# =============================================================================
# JETBRAINS RIDER / RESHARPER
# =============================================================================

.idea/
*.sln.iml
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
*.dotCover


# =============================================================================
# PUBLISH & DEPLOYMENT
# =============================================================================

publish/
*.[Pp]ublish.xml
*.azurePubxml
*.pubxml
*.pubxml.user
*.publishproj
PublishScripts/
csx/
*.build.csdef
ecf/
rcf/


# =============================================================================
# SECRETS & ENVIRONMENT
# =============================================================================

# Environment-specific appsettings with real credentials.
# appsettings.json and appsettings.Production.json ARE tracked because
# all sensitive fields are left empty (filled via user secrets or env vars).
appsettings.Development.json
appsettings.Development.local.json
appsettings.Local.json
appsettings.*.local.json

# .env files (Docker / deployment convenience files)
.env
.env.*
!.env.example

# Certificates and private keys
*.pfx
*.p12
*.cer
*.pem
*.key


# =============================================================================
# LOGS
# =============================================================================

# Serilog writes daily files under Logs/ (e.g. log-20260517.txt)
**/Logs/
*.log


# =============================================================================
# SQL SERVER LOCAL DATABASE FILES
# =============================================================================

*.mdf
*.ldf
*.ndf


# =============================================================================
# TEST & COVERAGE ARTIFACTS
# =============================================================================

[Tt]est[Rr]esult*/
TestOutput/
coverage/
coverage-report/
lcov.info
*.coverage
*.coveragexml
cobertura.xml
opencover.xml


# =============================================================================
# DOCKER — LOCAL OVERRIDES
# =============================================================================

# Base docker-compose.yml is tracked; local overrides are not.
docker-compose.override.yml
docker-compose.local.yml
.docker/


# =============================================================================
# REDIS / CACHE DUMPS
# =============================================================================

dump.rdb
*.rdb


# =============================================================================
# RUNTIME USER-UPLOADED FILES
# =============================================================================
#
# Files in wwwroot/uploads/ are written at runtime and must NOT be committed.
# They belong on the deployment server or an object-storage bucket (S3/Blob).
#
# EXCEPTION — wwwroot/uploads/mango-types/ IS intentionally tracked.
# Those images are referenced by EF Core seed data in AppDbContext.OnModelCreating
# and must be present in every fresh clone so the mango catalog has images.
#
**/wwwroot/uploads/users/
**/wwwroot/uploads/complaints/
**/wwwroot/uploads/feedbacks/


# =============================================================================
# CLAUDE CODE — LOCAL SETTINGS
# =============================================================================

# Team-shared Claude commands/rules under .claude/ ARE tracked.
# The local settings file is machine-specific and must NOT be committed.
.claude/settings.local.json


# =============================================================================
# MACOS SYSTEM FILES
# =============================================================================

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes


# =============================================================================
# WINDOWS SYSTEM FILES
# =============================================================================

Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/


# =============================================================================
# MISCELLANEOUS
# =============================================================================

# Temp / scratch files
*.tmp
*.tmp_proj
~$*
*~

# DNX (legacy, kept for safety)
project.lock.json

# NuGet (legacy patterns)
*.nuget.props
*.nuget.targets

# Web workbench
.sass-cache/

# Node (if any frontend tooling is ever added to this repo)
node_modules/

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# NSwag / OpenAPI generated snapshots (checked in explicitly when needed)
# Uncomment the line below if you add a generated OpenAPI JSON to the repo:
# !src/RajMango.WebApi/OpenApi/*.json
