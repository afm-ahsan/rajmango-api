{
  "ConnectionStrings": {
    // Set via user secrets (dev) or environment variable CONNECTIONSTRINGS__DEFAULT (prod)
    // Example: "Server=HOST\\SQLEXPRESS;Database=RajMango;Trusted_Connection=True;TrustServerCertificate=True"
    "Default": ""
  },
  "Security": {
    "Jwt": {
      "ClientId": "RajMangoWebApi_Swagger",
      // Set via user secrets (dev) or environment variable SECURITY__JWT__CLIENTSECRET (prod)
      "ClientSecret": "",
      "Audience": "RajMangoWebApi",
      "Authority": "https://localhost:7213",
      "SecurityScheme": "Bearer",
      "Description": "OAuth2 security scheme for authentication and authorization"
    }
  },
  "Redis": {
    // Set ConnectionString via user secrets (dev) or environment variable REDIS__CONNECTIONSTRING (prod)
    // Example: "localhost:6379,password=secret,ssl=false,abortConnect=False"
    // Leave empty to fall back to in-process memory cache (dev/test only)
    "ConnectionString": "",
    "DefaultExpiryMinutes": 10
  },
  "Bkash": {
    // Set AppKey, AppSecret, Username, Password via user secrets (dev) or environment variables (prod)
    // Sandbox base URL: https://tokenized.sandbox.bka.sh/v1.2.0-beta/tokenized
    // Production base URL: https://tokenized.pay.bka.sh/v1.2.0-beta/tokenized
    "BaseUrl": "https://tokenized.sandbox.bka.sh/v1.2.0-beta/tokenized",
    "AppKey": "",
    "AppSecret": "",
    "Username": "",
    "Password": ""
  },
  "ApiInfo": {
    "Title": "RajMango WebApi",
    "Version": "v1",
    "Description": "RajMango WebApi"
  },
  "Swagger": {
    "Endpoint": "/swagger/v1/swagger.json",
    "Version": "Version 1.0",
    "OAuthAppName": "RajMango WebApi"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt", // File path pattern
          "rollingInterval": "Day", // New file daily
          "fileSizeLimitBytes": 5242880, //5 * 1024 * 1024,  -> 5 MB
          "rollOnFileSizeLimit": true, // Create new file if size exceeds
          "retainedFileCountLimit": 10, // Keep last 10 files
          "shared": true,
          "flushToDiskInterval": "00:00:01"
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
